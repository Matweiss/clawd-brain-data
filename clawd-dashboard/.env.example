# ────────────────────────────────────────────────────────────────────
# Browser-side (NEXT_PUBLIC_*) — safe to ship to the client bundle.
# These power the read-only dashboard via the Supabase publishable key
# and RLS anon-SELECT policies.
# ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://tntoclpqyisfttpchajh.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_W2mb9CIkmd78hjD7tw_29w_Vh53jX4o

# ────────────────────────────────────────────────────────────────────
# Server-side only — used by `npm run sync:hubspot`. NEVER prefix these
# with NEXT_PUBLIC_, NEVER import them from any file under app/.
# ────────────────────────────────────────────────────────────────────
# HubSpot Private App token. The old clawd-command-center project on
# this Vercel account has a HUBSPOT_TOKEN env var that may already be
# valid — check there first before generating a new one.
HUBSPOT_TOKEN=

# Supabase service role key. Find it in Supabase dashboard →
# Project Settings → API → service_role (do not commit).
SUPABASE_SERVICE_ROLE_KEY=

